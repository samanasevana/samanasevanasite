---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props as Props;
---

<nav class="mt-4 mb-5" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2 text-lg font-medium">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {item.href ? (
            <a
              href={item.href}
              class="text-zinc-500 transition hover:text-zinc-900 hover:underline dark:text-zinc-400 dark:hover:text-zinc-100"
            >
              {item.label}
            </a>
          ) : (
            <span class="text-zinc-900 dark:text-zinc-100">{item.label}</span>
          )}
          {i < items.length - 1 && (
            <span class="text-zinc-400 dark:text-zinc-500" aria-hidden="true">
              ›
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
