---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getLangFromUrl, localizedPath } from "../i18n/utils";
import { getLocalizedData } from "../i18n/content";

const lang = getLangFromUrl(Astro.url);
const nav = await getLocalizedData("navigation", lang);
const links = nav?.data.links ?? [];
---

<header
  class="relative z-50 mb-3 flex flex-wrap items-center justify-between gap-y-2 pb-3"
  transition:name="header"
>
  <nav class="flex flex-wrap items-center gap-x-4 gap-y-1">
    {
      links.map((link) => (
        <a href={localizedPath(link.href, lang)}>{link.label}</a>
      ))
    }
  </nav>
  <div class="flex items-center gap-2">
    <LanguageSwitcher />
    <ThemeToggle />
  </div>
</header>

<style>
  a {
    @apply font-medium text-zinc-500 hover:text-zinc-900 hover:underline dark:hover:text-zinc-100;
  }
</style>
