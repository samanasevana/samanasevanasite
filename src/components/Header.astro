---
import ThemeToggle from "./ThemeToggle.astro";
import { getEntry } from "astro:content";

const nav = await getEntry("navigation", "main");
const links = nav?.data.links ?? [];
---

<header
  class="mb-3 flex flex-wrap items-center justify-between gap-y-2 pb-3"
  transition:name="header"
>
  <nav class="flex flex-wrap items-center gap-x-4 gap-y-1">
    {links.map((link) => <a href={link.href}>{link.label}</a>)}
  </nav>
  <ThemeToggle />
</header>

<style>
  a {
    @apply font-medium text-zinc-500 hover:text-zinc-900 hover:underline dark:hover:text-zinc-100;
  }
</style>
