---
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Layout.astro";
import Accordion from "../../components/Accordion.astro";

const translationPosts = await getCollection("translation");
const readingsPosts = await getCollection("readings");
const sortedTranslationPosts = translationPosts.sort(
  (a, b) => a.data.order - b.data.order,
);
const sortedReadingsPosts = readingsPosts.sort((a, b) => a.data.order - b.data.order);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main>
    <section>
      <h2 class="mb-0 text-xl font-semibold">Translations</h2>
      <p class="mb-4 text-sm text-gray-600 dark:text-gray-400">
        by Venerable Jeffrey Hancuff (Bhante Guṇavīro)
      </p>
      <div class="flex flex-col gap-3">
        {
          sortedTranslationPosts.map(async (post) => {
            const { Content } = await post.render();
            return (
              <Accordion
                title={post.data.title}
                description={post.data.description}
                pdfSlug={post.slug}
              >
                <Content />
              </Accordion>
            );
          })
        }
      </div>
    </section>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-semibold">Further Readings</h2>
      <div class="flex flex-col gap-3">
        {
          sortedReadingsPosts.map(async (post) => {
            const { Content } = await post.render();
            return (
              <Accordion title={post.data.title} description={post.data.description}>
                <Content />
              </Accordion>
            );
          })
        }
      </div>
    </section>
  </main>
</Layout>

<script src="../../scripts/accordion.js"></script>
