---
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import Layout from "../layouts/Layout.astro";

import EventsTable from "../components/EventsTable.astro";
import { Content } from "../content/pages/index.md";

const homeSections = (await getCollection("homeSections")).sort(
  (a, b) => a.data.order - b.data.order,
);

const toneClasses = {
  emerald:
    "bg-emerald-50 text-emerald-700 ring-emerald-500/30 dark:bg-emerald-400/20 dark:text-emerald-50 dark:ring-emerald-300/30",
  amber:
    "bg-amber-50 text-amber-700 ring-amber-400/30 dark:bg-amber-300/20 dark:text-amber-50 dark:ring-amber-200/30",
  indigo:
    "bg-indigo-50 text-indigo-700 ring-indigo-500/30 dark:bg-indigo-100 dark:text-indigo-950 dark:ring-indigo-200/80",
  zinc: "bg-zinc-100 text-zinc-700 ring-zinc-400/30 dark:bg-zinc-700 dark:text-zinc-50 dark:ring-zinc-500/60",
} as const;
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main class="space-y-6">
    <div class="flex items-center gap-2">
      <img
        src="/static/bhante-1.png"
        alt="Venerable Jeffrey"
        class="h-36 w-full rounded-md border border-zinc-500/50 object-cover dark:border-zinc-700"
      />
      <img
        src="/static/bhante-2.png"
        alt="Leaf"
        class="h-36 w-full rounded-md border border-zinc-500/50 object-cover dark:border-zinc-700"
      />
    </div>
    <article class="space-y-6 text-base text-slate-700 dark:text-zinc-300">
      <div
        class="prose prose-slate dark:prose-invert max-w-none text-lg text-slate-900 dark:text-zinc-100"
      >
        <Content />
      </div>
      <div class="space-y-6">
        <div class="lg:mx-[-100px]">
          <EventsTable />
        </div>
        <div
          class="rounded-2xl border border-slate-200 bg-white p-5 shadow-md shadow-slate-200/70 dark:border-zinc-700/80 dark:bg-zinc-900/80 dark:shadow-black/30"
        >
          <div class="space-y-5 text-sm text-slate-700 dark:text-zinc-300">
            {
              homeSections.map(async (section, index) => {
                const { Content: SectionContent } = await section.render();
                return (
                  <>
                    <div>
                      <div class="mb-2 flex flex-wrap items-center gap-2">
                        <span
                          class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-wide ring-1 ring-inset ${
                            toneClasses[section.data.tone]
                          }`}
                        >
                          {section.data.badge}
                        </span>
                        {section.data.meta ? (
                          <span class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-zinc-400">
                            {section.data.meta}
                          </span>
                        ) : null}
                      </div>
                      <div class="prose prose-slate dark:prose-invert max-w-none text-base text-slate-700 dark:text-zinc-300">
                        <SectionContent />
                      </div>
                    </div>
                    {index < homeSections.length - 1 ? (
                      <hr class="border-slate-200 dark:border-zinc-700" />
                    ) : null}
                  </>
                );
              })
            }
          </div>
        </div>
      </div>
    </article>
  </main>
</Layout>
