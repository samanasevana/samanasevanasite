---
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Layout.astro";
import type { Lang } from "../../i18n/config";
import { i18nStaticPaths, useTranslations } from "../../i18n/utils";
import { entryLang, getLocalizedDoc } from "../../i18n/content";

export function getStaticPaths() {
  return i18nStaticPaths();
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

const doc = await getLocalizedDoc("pages", "updates", lang);
if (!doc) throw new Error("Missing pages/updates document");
const { Content } = await doc.render();
const showFallback = entryLang(doc.slug) !== lang;
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main>
    <article>
      {
        showFallback && (
          <p class="mb-4 rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-800 dark:border-amber-300/30 dark:bg-amber-400/10 dark:text-amber-200">
            {t("translationFallback")}
          </p>
        )
      }
      <Content />
    </article>
  </main>
</Layout>
