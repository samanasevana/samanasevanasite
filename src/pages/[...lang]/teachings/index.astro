---
import { SITE_DESCRIPTION, SITE_TITLE } from "../../../consts";
import type { Lang } from "../../../i18n/config";
import {
  i18nStaticPaths,
  localizedPath,
  useTranslations,
} from "../../../i18n/utils";
import Layout from "../../../layouts/Layout.astro";

export function getStaticPaths() {
  return i18nStaticPaths();
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

const cards = [
  {
    href: "/teachings/introduction",
    title: t("introBuddhism"),
    byline: t("byline"),
    description: t("introBuddhismDesc"),
  },
  {
    href: "/teachings/translations",
    title: t("translationsBuddhasWords"),
    byline: t("byline"),
    description: t("translationsBuddhasWordsDesc"),
  },
  {
    href: "/teachings/talks",
    title: t("talks"),
    byline: null,
    description: t("talksDesc"),
  },
  {
    href: "/teachings/guided-meditations",
    title: t("guidedMeditations"),
    byline: null,
    description: t("guidedMeditationsDesc"),
  },
  {
    href: "/teachings/writings",
    title: t("writings"),
    byline: null,
    description: t("writingsDesc"),
  },
];
---

<Layout
  title={`${t("teachings")} - ${SITE_TITLE}`}
  description={SITE_DESCRIPTION}
>
  <main>
    <section class="mt-4">
      <h1 class="mb-6 text-lg font-medium">{t("teachings")}</h1>
      <div class="grid gap-4">
        {
          cards.map((card) => (
            <a
              href={localizedPath(card.href, lang)}
              class="group flex flex-col gap-1 rounded-md border border-[#CC5500] p-4 transition hover:bg-[#CC5500]/5"
            >
              <span class="font-medium transition group-hover:text-[#CC5500]">
                {card.title}
              </span>
              <span class="text-sm text-gray-600 dark:text-gray-400">
                {card.byline ?? card.description}
              </span>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
