---
import { type CollectionEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import type { Lang } from "../../../i18n/config";
import { useTranslations } from "../../../i18n/utils";
import { entryLang, getLocalizedPostPaths } from "../../../i18n/content";

export async function getStaticPaths() {
  return getLocalizedPostPaths("reflection");
}

type Props = {
  entry: CollectionEntry<"reflection">;
  lang: Lang;
  base: string;
};

const { entry, lang, base } = Astro.props as Props;
const t = useTranslations(lang);
const { Content } = await entry.render();
const pdfHref = `/pdfs/${entryLang(entry.slug)}/${base}.pdf`;
const showFallback = entryLang(entry.slug) !== lang;
---

<Layout title={entry.data.title}>
  <main>
    <div class="flex items-start justify-between">
      <div>
        <h1 class="mb-2 text-xl font-medium">
          {entry.data.title}
        </h1>
      </div>
      <a
        href={pdfHref}
        class="rounded bg-blue-800 px-2 py-1 text-sm font-semibold text-white underline"
      >
        {t("pdfVersion")}
      </a>
    </div>

    {
      showFallback && (
        <p class="mb-4 rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-800 dark:border-amber-300/30 dark:bg-amber-400/10 dark:text-amber-200">
          {t("translationFallback")}
        </p>
      )
    }

    <article>
      <Content />
    </article>
  </main>
</Layout>
